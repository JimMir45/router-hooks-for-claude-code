# Secrets — never commit
config/keys.json
*.key
*.pem
*.env
.env*

# Logs and runtime data
*.log
logs/
reports/
~/.claude/router-logs/

# Python
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test output — keep main result files committed (they are deliverables);
# only ignore local intermediate logs.
tests/results/*.log
tests/results/.isolated-home/
tests/results/.uninstall-test/

# Active plan is per-worktree session state, not part of the public repo
.claude/

# Demo deliverables — keynote and whitepaper were one-off presentation artifacts,
# not part of the open-source deliverable. Keep them locally.
demo/

# Internal working notes (not meant for the public repo)
NEXT-STEPS.md
